{#
| component                    | object    | Merchant settings from twilight.json                           |
| component.rank_one_products  | Product[] | Product picker for rank 1                                      |
| component.rank_two_products  | Product[] | Product picker for rank 2                                      |
| component.rank_three_products| Product[] | Product picker for rank 3                                      |
| component.rank_four_products | Product[] | Product picker for rank 4                                      |
| position                     | int       | Component order in the homepage                                |
#}

{% set rank_one_item = component.rank_one_products|default([])|first %}
{% set rank_two_item = component.rank_two_products|default([])|first %}
{% set rank_three_item = component.rank_three_products|default([])|first %}
{% set rank_four_item = component.rank_four_products|default([])|first %}

{% set rank_one_id = rank_one_item ? (rank_one_item.id ?: rank_one_item.value ?: rank_one_item) : null %}
{% set rank_two_id = rank_two_item ? (rank_two_item.id ?: rank_two_item.value ?: rank_two_item) : null %}
{% set rank_three_id = rank_three_item ? (rank_three_item.id ?: rank_three_item.value ?: rank_three_item) : null %}
{% set rank_four_id = rank_four_item ? (rank_four_item.id ?: rank_four_item.value ?: rank_four_item) : null %}

{% set selected_ids = [rank_one_id, rank_two_id, rank_three_id, rank_four_id]|filter(id => id)|join(',') %}
{% set has_products = selected_ids is not empty %}

<section
  class="s-block nukhba-top-three-products"
  style="
    --nukhba-top-three-bg: {{ component.background_color|default('#07081c') }};
    --nukhba-top-three-number: {{ component.number_color|default('#facc15') }};
    --nukhba-top-three-title: {{ component.title_color|default('#ffffff') }};
    --nukhba-top-three-card-bg: {{ component.card_background_color|default('#ffffff') }};
    --nukhba-top-three-text: {{ component.text_color|default('#111827') }};
    --nukhba-top-three-price: {{ component.price_color|default('#111827') }};
    --nukhba-top-three-old-price: {{ component.old_price_color|default('#6b7280') }};
    --nukhba-top-three-button-bg: {{ component.button_bg_color|default('#0f172a') }};
    --nukhba-top-three-button-text: {{ component.button_text_color|default('#ffffff') }};
  ">
  <div class="container">
    {% if component.section_title %}
      <header class="nukhba-top-three-products__heading">
        <h2>{{ component.section_title }}</h2>
      </header>
    {% endif %}

    {% if has_products %}
      <salla-products-list
        class="nukhba-top-three-products__list"
        source="selected"
        limit="4"
        source-value="[{{ selected_ids }}]"
        product-card-component="nukhba-top-three-product-card"
        slider-id="nukhba-top-three-products-{{ position }}"
      ></salla-products-list>
    {% endif %}
  </div>
</section>
