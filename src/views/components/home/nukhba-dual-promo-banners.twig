{#
| component                | object   | Fields from twilight.json                 |
| component.section_title  | ?string  | Optional section title                    |
| component.cards          | object[] | Two promo cards                           |
#}
<section class="s-block nukhba-showcase nukhba-dual-promos-block">
  <div class="container">
    {% if component.section_title %}
      <div class="nukhba-showcase__heading">
        <h2>{{ component.section_title }}</h2>
      </div>
    {% endif %}
    <div class="nukhba-dual-promos">
      {% for card in component.cards|slice(0, 2) %}
        {% set promo_style = '--nukhba-promo-bg:' ~ (card.bg_color ?: '#13c6f3') ~ ';--nukhba-promo-text:' ~ (card.text_color ?: '#111827') ~ ';' %}
        <a href="{{ card.url ?: '#' }}" class="nukhba-promo-banner" style="{{ promo_style }}" aria-label="{{ (card.title ?: store.name)|e('html_attr') }}">
          <div class="nukhba-promo-banner__copy">
            {% if card.overline %}<span class="nukhba-promo-banner__overline">{{ card.overline }}</span>{% endif %}
            {% if card.title %}<h3>{{ card.title }}</h3>{% endif %}
            {% if card.description %}<p>{{ card.description }}</p>{% endif %}
          </div>
          {% if card.image %}
            <div class="nukhba-promo-banner__media">
              <img src="{{ card.image }}" alt="{{ card.title ?: store.name }}" loading="lazy" width="900" height="420" />
            </div>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>
