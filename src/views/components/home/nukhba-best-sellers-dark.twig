{#
| component               | object    | Fields from twilight.json             |
| component.section_title | ?string   | Title                                 |
| component.tabs          | object[]  | Pills row                             |
| component.products      | Product[] | Selected products                     |
#}
{% set selected_ids = component.products|default([])|map((item) => item.id ?: item.value ?: item)|join(',') %}
<section class="s-block nukhba-showcase nukhba-best-sellers-dark-block">
  <div class="container">
    <div class="nukhba-showcase__heading nukhba-showcase__heading--reverse">
      <h2>{{ component.section_title ?: 'الأفضل مبيعًا' }}</h2>
      {% if component.tabs|length %}
        <div class="nukhba-chip-row">
          {% for tab in component.tabs %}
            <a href="{{ tab.url ?: '#' }}" class="nukhba-chip-row__item is-outline">{{ tab.title }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    {% if selected_ids %}
      <salla-products-slider
        class="nukhba-best-sellers-dark"
        source="selected"
        limit="4"
        source-value="[{{ selected_ids }}]"
        slider-id="nukhba-best-sellers-dark-{{ position }}"
        product-card-component="nukhba-product-card-showcase"
        data-show-rating="true"
        data-show-button="true"
        data-compact="false">
      </salla-products-slider>
    {% endif %}
  </div>
</section>
