{#
| component                | object   | Fields from twilight.json               |
| component.left_banners   | object[] | Left column promos                      |
| component.center_items   | object[] | Center deal items                       |
| component.right_tiles    | object[] | Right tiles                             |
#}
<section class="s-block nukhba-showcase nukhba-editorial-board-block">
  <div class="container">
    <div class="nukhba-editorial-board">
      <div class="nukhba-editorial-board__left">
        <h3>{{ component.left_title ?: 'عليها العين' }}</h3>
        {% for banner in component.left_banners|slice(0, 2) %}
          <a href="{{ banner.url ?: '#' }}" class="nukhba-editorial-banner" aria-label="{{ (banner.title ?: store.name)|e('html_attr') }}">
            {% if banner.image %}
              <img src="{{ banner.image }}" alt="{{ banner.title ?: store.name }}" loading="lazy" width="620" height="300" />
            {% endif %}
            <div class="nukhba-editorial-banner__copy">
              {% if banner.badge %}<span>{{ banner.badge }}</span>{% endif %}
              {% if banner.title %}<h4>{{ banner.title }}</h4>{% endif %}
              {% if banner.description %}<p>{{ banner.description }}</p>{% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
      <div class="nukhba-editorial-board__center">
        <div class="nukhba-editorial-board__center-head">
          {% if component.countdown %}<span>{{ component.countdown }}</span>{% endif %}
          <h3>{{ component.center_title ?: 'عروض مبهرة' }}</h3>
        </div>
        <div class="nukhba-editorial-items">
          {% for item in component.center_items|slice(0, 4) %}
            <a href="{{ item.url ?: '#' }}" class="nukhba-editorial-item" aria-label="{{ (item.title ?: store.name)|e('html_attr') }}">
              {% if item.badge %}<span class="nukhba-editorial-item__badge">{{ item.badge }}</span>{% endif %}
              {% if item.image %}
                <img src="{{ item.image }}" alt="{{ item.title ?: store.name }}" loading="lazy" width="240" height="240" />
              {% endif %}
              <h4>{{ item.title }}</h4>
              <div class="nukhba-editorial-item__price">
                {% if item.old_price %}<span>{{ item.old_price }}</span>{% endif %}
                {% if item.price %}<strong>{{ item.price }}</strong>{% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
      <div class="nukhba-editorial-board__right">
        <h3>{{ component.right_title ?: 'نوفرها أكثر' }}</h3>
        <div class="nukhba-editorial-tiles">
          {% for tile in component.right_tiles|slice(0, 4) %}
            <a href="{{ tile.url ?: '#' }}" class="nukhba-editorial-tile" aria-label="{{ (tile.title ?: store.name)|e('html_attr') }}">
              {% if tile.image %}
                <img src="{{ tile.image }}" alt="{{ tile.title ?: store.name }}" loading="lazy" width="280" height="220" />
              {% endif %}
              <h4>{{ tile.title }}</h4>
              {% if tile.description %}<p>{{ tile.description }}</p>{% endif %}
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
