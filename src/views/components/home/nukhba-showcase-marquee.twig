{#
| component                  | object   | Fields from twilight.json               |
| component.left_image       | string   | Left promo image                        |
| component.left_title       | ?string  | Left title                              |
| component.left_button      | ?string  | Left button label                       |
| component.left_url         | ?string  | Left url                                |
| component.slides           | object[] | Right slides                            |
| component.icon_items       | object[] | Bottom icon items                       |
| position                   | int      | Component position                      |
#}
<section class="s-block nukhba-showcase nukhba-marquee-block">
  <div class="container">
    <div class="nukhba-marquee-top">
      <a href="{{ component.left_url ?: '#' }}" class="nukhba-marquee-top__left" aria-label="{{ (component.left_title ?: store.name)|e('html_attr') }}">
        {% if component.left_image %}
          <img src="{{ component.left_image }}" alt="{{ component.left_title ?: store.name }}" loading="lazy" width="720" height="340" />
        {% endif %}
        <div class="nukhba-marquee-top__overlay">
          {% if component.left_title %}<h3>{{ component.left_title }}</h3>{% endif %}
          {% if component.left_button %}<span>{{ component.left_button }}</span>{% endif %}
        </div>
      </a>
      <div class="nukhba-marquee-top__right">
        <salla-slider
          id="nukhba-showcase-marquee-{{ position }}"
          auto-play
          pagination
          type="fullwidth">
          <div slot="items">
            {% for slide in component.slides %}
              <div class="swiper-slide">
                <a href="{{ slide.url ?: '#' }}" class="nukhba-marquee-slide" aria-label="{{ (slide.title ?: store.name)|e('html_attr') }}">
                  {% if slide.image %}
                    <img src="{{ slide.image }}" alt="{{ slide.title ?: store.name }}" loading="lazy" width="1000" height="340" />
                  {% endif %}
                  <div class="nukhba-marquee-slide__copy">
                    {% if slide.badge %}<span>{{ slide.badge }}</span>{% endif %}
                    {% if slide.title %}<h3>{{ slide.title }}</h3>{% endif %}
                    {% if slide.description %}<p>{{ slide.description }}</p>{% endif %}
                    {% if slide.code %}<strong>{{ slide.code }}</strong>{% endif %}
                  </div>
                </a>
              </div>
            {% endfor %}
          </div>
        </salla-slider>
      </div>
    </div>
    <div class="nukhba-marquee-icons">
      <salla-slider type="carousel" centered id="nukhba-showcase-icons-{{ position }}">
        <div slot="items">
          {% for item in component.icon_items %}
            <div class="swiper-slide slide--one-sixth">
              <a href="{{ item.url ?: '#' }}" class="nukhba-marquee-icon" aria-label="{{ (item.title ?: store.name)|e('html_attr') }}">
                <div class="nukhba-marquee-icon__frame">
                  {% if item.image %}
                    <img src="{{ item.image }}" alt="{{ item.title ?: store.name }}" loading="lazy" width="160" height="160" />
                  {% endif %}
                </div>
                {% if item.title %}<h4>{{ item.title }}</h4>{% endif %}
              </a>
            </div>
          {% endfor %}
        </div>
      </salla-slider>
    </div>
  </div>
</section>
