{#
| component                      | object   | Contains merchant settings for fields from twilight.json `component` section |
| component.desktop_image        | string   | Banner desktop image                                                          |
| component.mobile_image         | string   | Banner mobile image                                                           |
| component.url                  | ?string  | Banner link                                                                   |
| component.alt                  | ?string  | Banner alt                                                                    |
| component.desktop_height       | int      | Banner height on desktop                                                      |
| component.mobile_height        | int      | Banner height on mobile                                                       |
#}
{% set banner_alt = component.alt ?: store.name %}
{% set desktop_height = component.desktop_height ?: 420 %}
{% set mobile_height = component.mobile_height ?: 320 %}
{% set banner_style = '--nukhba-banner-desktop-height:' ~ desktop_height ~ 'px;--nukhba-banner-mobile-height:' ~ mobile_height ~ 'px;' %}

<section class="s-block s-block--full-bg nukhba-hero-block">
  {% if component.url %}
    <a href="{{ component.url }}" class="nukhba-hero-frame" aria-label="{{ banner_alt|e('html_attr') }}" style="{{ banner_style }}">
      <picture class="nukhba-hero-picture">
        <source media="(max-width: 1023px)" srcset="{{ component.mobile_image }}" />
        <img src="{{ component.desktop_image }}" alt="{{ banner_alt }}" loading="lazy" fetchpriority="high" width="1920" height="{{ desktop_height }}">
      </picture>
    </a>
  {% else %}
    <div class="nukhba-hero-frame" style="{{ banner_style }}">
      <picture class="nukhba-hero-picture">
        <source media="(max-width: 1023px)" srcset="{{ component.mobile_image }}" />
        <img src="{{ component.desktop_image }}" alt="{{ banner_alt }}" loading="lazy" fetchpriority="high" width="1920" height="{{ desktop_height }}">
      </picture>
    </div>
  {% endif %}
</section>
