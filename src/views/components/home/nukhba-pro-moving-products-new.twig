{#
| component                    | object    | Fields from twilight.json                        |
| component.products           | Product[] | Selected products                                |
| component.categories         | Category[]| Selected categories                              |
| component.brands             | Brand[]   | Selected brands                                  |
| component.installment_images | object[]  | Installment logos                                |
| position                     | int       | Sorting position                                 |
#}
{% set source_type = component.source_type ?: 'latest' %}
{% set selected_products = component.products|default([])|map((item) => item.id ?: item.value ?: item)|join(',') %}
{% set selected_categories = component.categories|default([])|map((item) => item.id ?: item.value ?: item)|join(',') %}
{% set selected_brands = component.brands|default([])|map((item) => item.id ?: item.value ?: item)|join(',') %}
{% set slider_source = source_type %}
{% set slider_values = source_type == 'selected' ? selected_products : (source_type == 'categories' ? selected_categories : (source_type == 'brands' ? selected_brands : '')) %}
{% set needs_source_value = source_type in ['selected', 'categories', 'brands'] %}
{% set has_products = (not needs_source_value) or slider_values %}
{% set slider_limit = component.products_limit ?: 32 %}
{% set desktop_height = component.desktop_image_height ?: 272 %}
{% set mobile_height = component.mobile_image_height ?: 208 %}
{% set width_mode = component.width_mode ?: 'normal' %}

<section
  class="s-block nukhba-pro-products nukhba-pro-products--reborn {{ width_mode == 'full' ? 'nukhba-pro-products--full' : 'nukhba-pro-products--normal' }}"
  style="
    --nukhba-pro-card-image-height: {{ desktop_height }}px;
    --nukhba-pro-card-image-height-mobile: {{ mobile_height }}px;
  ">
  <div class="{{ width_mode == 'full' ? 'nukhba-pro-products__inner' : 'container nukhba-pro-products__inner' }}">
    {% if has_products %}
      <salla-products-slider
        class="nukhba-pro-products-new__slider"
        source="{{ slider_source }}"
        limit="{{ slider_limit }}"
        autoplay
        slider-id="nukhba-pro-moving-products-new-{{ position }}"
        block-title="{{ component.section_title|default('أحدث المنتجات') }}"
        {% if component.section_subtitle %}
          block-subTitle="{{ component.section_subtitle }}"
        {% endif %}
        {% if component.display_all_url and component.display_all_url != '#' %}
          display-all-url="{{ component.display_all_url }}"
        {% endif %}
        {% if needs_source_value %}
          source-value="[{{ slider_values }}]"
        {% endif %}
      ></salla-products-slider>
    {% endif %}
  </div>
</section>
