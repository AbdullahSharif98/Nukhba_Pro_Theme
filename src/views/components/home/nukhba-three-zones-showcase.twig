{#
| component               | object   | Contains merchant settings for fields from twilight.json            |
| component.right_cards   | object[] | Right side cards                                                    |
| component.center_cards  | object[] | Center side cards                                                   |
| component.left_banners  | object[] | Left side stacked banners                                           |
| position                | int      | Sorting number starts from zero                                     |
#}

<section
  class="s-block nukhba-three-zones-showcase"
  style="
    --nukhba-showcase-bg: {{ component.section_bg_color|default('#eef7f7') }};
    --nukhba-showcase-panel-bg: {{ component.panel_bg_color|default('#ffffff') }};
    --nukhba-showcase-badge-bg: {{ component.badge_bg_color|default('#155e75') }};
    --nukhba-showcase-badge-text: {{ component.badge_text_color|default('#ffffff') }};
    --nukhba-showcase-title: {{ component.title_color|default('#374151') }};
    --nukhba-showcase-text: {{ component.text_color|default('#4b5563') }};
  ">
  <div class="container">
    <div class="nukhba-three-zones-showcase__grid">
      <section class="nukhba-three-zones-showcase__column nukhba-three-zones-showcase__column--right">
        {% if component.right_title %}
          <header class="nukhba-three-zones-showcase__header">
            <h2>{{ component.right_title }}</h2>
          </header>
        {% endif %}

        <div class="nukhba-three-zones-showcase__cards">
          {% for item in component.right_cards|slice(0, 4) %}
            <a href="{{ item.url }}" class="nukhba-three-zones-showcase__card" aria-label="{{ item.title|default('right-card-' ~ loop.index)|e('html_attr') }}">
              <div class="nukhba-three-zones-showcase__image-wrap">
                <img src="{{ item.image }}" alt="{{ item.title|default(store.name)|e('html_attr') }}" loading="lazy" width="420" height="280" />
              </div>
              <div class="nukhba-three-zones-showcase__copy">
                {% if item.title %}<h3>{{ item.title }}</h3>{% endif %}
                {% if item.description %}<p>{{ item.description }}</p>{% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      </section>

      <section class="nukhba-three-zones-showcase__column nukhba-three-zones-showcase__column--center">
        {% if component.center_countdown_end_at %}
          <div class="nukhba-three-zones-showcase__countdown">
            <salla-count-down date="{{ component.center_countdown_end_at }}" boxed></salla-count-down>
          </div>
        {% endif %}

        <header class="nukhba-three-zones-showcase__header nukhba-three-zones-showcase__header--center">
          {% if component.center_display_all_url %}
            <a href="{{ component.center_display_all_url }}" class="nukhba-three-zones-showcase__display-all">
              {{ component.center_display_all_text|default(trans('blocks.home.display_all')) }}
            </a>
          {% endif %}
          {% if component.center_title %}
            <h2>{{ component.center_title }}</h2>
          {% endif %}
        </header>

        <div class="nukhba-three-zones-showcase__cards">
          {% for item in component.center_cards|slice(0, 4) %}
            <a href="{{ item.url }}" class="nukhba-three-zones-showcase__card" aria-label="{{ item.title|default('center-card-' ~ loop.index)|e('html_attr') }}">
              {% if item.badge %}
                <span class="nukhba-three-zones-showcase__badge">{{ item.badge }}</span>
              {% endif %}
              <div class="nukhba-three-zones-showcase__image-wrap">
                <img src="{{ item.image }}" alt="{{ item.title|default(store.name)|e('html_attr') }}" loading="lazy" width="420" height="280" />
              </div>
              <div class="nukhba-three-zones-showcase__copy">
                {% if item.title %}<h3>{{ item.title }}</h3>{% endif %}
                {% if item.description %}<p>{{ item.description }}</p>{% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      </section>

      <section class="nukhba-three-zones-showcase__column nukhba-three-zones-showcase__column--left">
        {% if component.left_title %}
          <header class="nukhba-three-zones-showcase__header">
            <h2>{{ component.left_title }}</h2>
          </header>
        {% endif %}

        <div class="nukhba-three-zones-showcase__stack">
          {% for item in component.left_banners|slice(0, 2) %}
            <a href="{{ item.url }}" class="nukhba-three-zones-showcase__stack-item" aria-label="{{ item.alt|default('left-banner-' ~ loop.index)|e('html_attr') }}">
              <img src="{{ item.image }}" alt="{{ item.alt|default(store.name)|e('html_attr') }}" loading="lazy" width="900" height="520" />
            </a>
          {% endfor %}
        </div>
      </section>
    </div>
  </div>
</section>
