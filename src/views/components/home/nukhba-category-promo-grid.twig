{#
| component               | object   | Fields from twilight.json             |
| component.section_title | ?string  | Optional title                        |
| component.cards         | object[] | Promo category cards                  |
#}
{% set section_text_alignment = component.section_text_alignment ?: 'right' %}
{% set card_text_alignment = component.card_text_alignment ?: 'right' %}
<section class="s-block nukhba-showcase nukhba-category-promo-grid-block">
  <div class="container">
    {% if component.section_title %}
      <div class="nukhba-showcase__heading nukhba-showcase__heading--align-{{ section_text_alignment|e('html_attr') }}">
        <h2>{{ component.section_title }}</h2>
      </div>
    {% endif %}
    <div class="nukhba-category-promo-grid">
      {% for card in component.cards %}
        <a href="{{ card.url ?: '#' }}" class="nukhba-category-promo-card" aria-label="{{ (card.title ?: store.name)|e('html_attr') }}">
          <div class="nukhba-category-promo-card__copy nukhba-copy-align-{{ card_text_alignment|e('html_attr') }}">
            {% if card.title %}<h3>{{ card.title }}</h3>{% endif %}
            {% if card.subtitle %}<p>{{ card.subtitle }}</p>{% endif %}
          </div>
          {% if card.image %}
            <div class="nukhba-category-promo-card__media">
              <img src="{{ card.image }}" alt="{{ card.title ?: store.name }}" loading="lazy" width="520" height="240" />
            </div>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>
